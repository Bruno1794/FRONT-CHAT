NEXT_PUBLIC_API_URL=https://apichat.sytes.net

# Diretorio persistente usado pela rota /api/chat-popup para salvar configuracao.
# Na VPS, use uma pasta gravavel pelo usuario do PM2.
CHAT_POPUP_CONFIG_DIR=.data

# Popup inicial do chat
NEXT_PUBLIC_CHAT_OPENING_POPUP_ENABLED=false
NEXT_PUBLIC_CHAT_OPENING_POPUP_ID=welcome-v1
NEXT_PUBLIC_CHAT_OPENING_POPUP_TITLE=Bem-vindo ao atendimento
NEXT_PUBLIC_CHAT_OPENING_POPUP_MESSAGE=Antes de iniciar, confira nossos horarios de atendimento.
NEXT_PUBLIC_CHAT_OPENING_POPUP_IMAGE_URL=
NEXT_PUBLIC_CHAT_OPENING_POPUP_IMAGE_ALT=Aviso do atendimento
NEXT_PUBLIC_CHAT_OPENING_POPUP_CTA_LABEL=
NEXT_PUBLIC_CHAT_OPENING_POPUP_CTA_URL=
NEXT_PUBLIC_CHAT_OPENING_POPUP_DISMISS_HOURS=24
NEXT_PUBLIC_CHAT_OPENING_POPUP_DISMISS_DAYS=7
NEXT_PUBLIC_CHAT_OPENING_POPUP_DELAY_MS=500
NEXT_PUBLIC_CHAT_OPENING_POPUP_ALLOW_MARK_AS_SEEN=true
NEXT_PUBLIC_CHAT_OPENING_POPUP_CLOSE_ON_BACKDROP=true
NEXT_PUBLIC_CHAT_OPENING_POPUP_REQUIRE_CONVERSATION=false
